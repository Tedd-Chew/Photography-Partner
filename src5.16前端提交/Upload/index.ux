  }

  .mode-list {
    flex-direction: column;
  }

  .mode-item {
    flex-direction: row;
    align-items: center;
    padding: 14px 16px;
    margin-bottom: 8px;
    border-radius: 12px;
    background-color: #1a1a2e;
    border: 2px solid #2a2a4a;
  }

  .mode-item.active {
    border-color: #ffd700;
