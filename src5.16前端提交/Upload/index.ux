<script>
import router from '@system.router'
import media from '@system.media'
import { store } from '../store/index.js'
import { analyzePhoto } from '../services/api.js'
import { compressImage } from '../helper/image.js'
import { saveToHistoryCache } from '../helper/storage.js'

export default {
  data: {
    selectedImage: null,
    mode: 'score',
    loading: false
  },

  onInit() {
    store.clearAnalysis()
  },

  onPickImage() {
    const self = this
    media.pickImage({
      success: function (data) {
        self.selectedImage = data.uri
      },
      fail: function (err) {
        console.log('选择图片失败:', err)
      }
    })
  },

  onTakePhoto() {
    const self = this
    media.takePhoto({
      success: function (data) {
        self.selectedImage = data.uri
      },
      fail: function (err) {
        console.log('拍照失败:', err)
      }
    })
  },

  onSelectMode(mode) {
    this.mode = mode
    store.setAnalysisMode(mode)
  },

  onResetImage() {
    store.clearAnalysis()
    this.selectedImage = null
  },

  navigateTo(page) {
    router.push({ uri: '/' + page })
  },

  async onAnalyze() {
    if (!this.selectedImage) return

    this.loading = true
    store.setLoading(true)

    try {
      const compressedUri = await compressImage(this.selectedImage)
      const result = await analyzePhoto(compressedUri, this.mode)

      if (result.ok) {
        store.setAnalysis(result.data)
        store.setCurrentImage(this.selectedImage)

        saveToHistoryCache({
          id: result.data.id,
          mode: this.mode,
          score: result.data.score || null,
          scene: result.data.scene || null,
          comment: result.data.comment || result.data.advice || null,
          created_at: new Date().toISOString()
        })

        router.push({ uri: '/Result' })
      } else {
        this.showToast(result.error || '分析失败，请重试')
      }
    } catch (e) {
      this.showToast('分析失败: ' + (e.message || '网络异常'))
    } finally {
      this.loading = false
      store.setLoading(false)
    }
  },

  showToast(msg) {
    try {
      const prompt = require('@system.prompt')
      prompt.showToast({ message: msg, duration: 1 })
    } catch (e) {
      console.log(msg)
    }
  }
}
</script>

<template>
  <div class="upload-page">
    <div class="header">
      <text class="title">光影参谋</text>
      <text class="subtitle">AI 摄影构图成长伴侣</text>
    </div>

    <div if="{{!selectedImage}}" class="select-area">
      <div class="select-card" onclick="onPickImage">
        <image class="select-icon" src="/Common/icons/album.png"></image>
        <text class="select-label">从相册选择</text>
      </div>
      <div class="select-card" onclick="onTakePhoto">
        <image class="select-icon" src="/Common/icons/camera.png"></image>
        <text class="select-label">拍摄照片</text>
      </div>
    </div>

    <div if="{{selectedImage}}" class="preview-area">
      <image class="preview-img" src="{{selectedImage}}"></image>

      <div class="mode-selector">
        <text class="mode-title">选择分析模式</text>
        <div class="mode-list">
          <div class="mode-item {{mode === 'shooting' ? 'active' : ''}}" onclick="onSelectMode('shooting')">
            <text class="mode-icon">📷</text>
            <text class="mode-name">拍摄指导</text>
            <text class="mode-desc">这个场景怎么拍？</text>
          </div>
          <div class="mode-item {{mode === 'edit' ? 'active' : ''}}" onclick="onSelectMode('edit')">
            <text class="mode-icon">🔧</text>
            <text class="mode-name">修图建议</text>
            <text class="mode-desc">怎么后期调色修图？</text>
          </div>
          <div class="mode-item {{mode === 'score' ? 'active' : ''}}" onclick="onSelectMode('score')">
            <text class="mode-icon">⭐</text>
            <text class="mode-name">评分评价</text>
            <text class="mode-desc">这张照片打几分？</text>
          </div>
        </div>
      </div>

      <div class="action-bar">
        <div class="btn-reselect" onclick="onResetImage">
          <text>重选照片</text>
        </div>
        <div class="btn-analyze" onclick="onAnalyze">
          <text>开始分析</text>
        </div>
      </div>
    </div>

    <div if="{{loading}}" class="loading-overlay">
      <div class="loading-box">
        <progress type="circular"></progress>
        <text class="loading-text">AI 正在分析中...</text>
        <text class="loading-hint">预计需要 2-3 秒</text>
      </div>
    </div>

    <div class="nav-bar">
      <div class="nav-item" onclick="navigateTo('Gallery')">
        <text>📋 历史</text>
      </div>
      <div class="nav-item" onclick="navigateTo('Camera')">
        <text>📸 实拍</text>
      </div>
      <div class="nav-item" onclick="navigateTo('Growth')">
        <text>🌟 成长</text>
      </div>
    </div>
  </div>
</template>

