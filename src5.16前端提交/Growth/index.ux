  }

  .exp-text {
    font-size: 13px;
    color: #888;
    margin-top: 10px;
  }

  .badge-section {
    flex-direction: column;
    margin-bottom: 20px;
  }

  .section-label {
    font-size: 16px;
    font-weight: bold;
    color: #ffd700;
    margin-bottom: 12px;
  }

  .badge-list {
    flex-direction: row;
    flex-wrap: wrap;
  }

  .badge-tag {
    padding: 8px 16px;
