<script>
import router from '@system.router'
import { store } from '../store/index.js'
import { getUserInfo } from '../services/api.js'

export default {
  data: {
    user: null,
    loading: true
  },

  async onInit() {
    await this.loadUser()
  },

  async loadUser() {
    this.loading = true
    try {
      const res = await getUserInfo()
      if (res.ok) {
        this.user = res.data
        store.setUser(res.data)
      }
    } catch (e) {
      console.log('加载用户信息失败:', e)
    } finally {
      this.loading = false
    }
  },

  getExpPercent(exp, level) {
    const thresholds = { 1: 100, 2: 100, 3: 200, 4: 300, 5: 400, 6: 600 }
    const bases = { 1: 0, 2: 100, 3: 200, 4: 400, 5: 700, 6: 1100 }
    const base = bases[level] || 0
    const need = thresholds[level] || 100
    return Math.min(100, Math.round(((exp - base) / need) * 100))
  },

  getNextLevelExp(level) {
    const thresholds = { 1: 100, 2: 200, 3: 400, 4: 700, 5: 1100, 6: 1600 }
    return thresholds[level] || 1600
  },

  getLevelTitle(level) {
    const titles = {
      1: '摄影新手',
      2: '摄影学徒',
      3: '摄影达人',
      4: '摄影专家',
      5: '摄影大师',
      6: '光影艺术家'
    }
    return titles[level] || '摄影新手'
  },

  goBack() {
    router.back()
  },

  showToast(msg) {
    try {
      const prompt = require('@system.prompt')
      prompt.showToast({ message: msg, duration: 1 })
    } catch (e) {
      console.log(msg)
    }
  }
}
</script>

<template>
  <div class="growth-page">
    <div class="header">
      <div class="back-btn" onclick="goBack">
        <text>← 返回</text>
      </div>
      <text class="header-title">我的成长</text>
      <div class="header-right"></div>
    </div>

    <div if="{{loading}}" class="loading-area">
      <progress type="circular"></progress>
      <text class="loading-text">加载中...</text>
    </div>

    <div if="{{!loading && user}}" class="content">
      <div class="level-card">
        <text class="level-num">Lv.{{user.level}}</text>
        <text class="level-title">{{getLevelTitle(user.level)}}</text>
        <div class="exp-bar-bg">
          <div class="exp-bar-fill" style="width: {{getExpPercent(user.exp, user.level)}}%;"></div>
        </div>
        <text class="exp-text">{{user.exp}} / {{getNextLevelExp(user.level)}} EXP</text>
      </div>

      <div class="badge-section">
        <text class="section-label">🏅 勋章 ({{user.badges.length}}/8)</text>
        <div if="{{user.badges.length}}" class="badge-list">
          <div for="b in user.badges" class="badge-tag">
            <text class="badge-name">{{b}}</text>
          </div>
        </div>
        <text if="{{!user.badges.length}}" class="empty-hint">还没有获得勋章，快去分析照片吧</text>
      </div>

      <div class="stats-section">
        <text class="section-label">📊 统计</text>
        <div class="stats-grid">
          <div class="stat-item">
            <text class="stat-num">{{user.total_analyses}}</text>
            <text class="stat-label">累计分析</text>
          </div>
          <div class="stat-item">
            <text class="stat-num">{{user.level}}</text>
            <text class="stat-label">当前等级</text>
          </div>
          <div class="stat-item">
            <text class="stat-num">{{user.badges.length}}</text>
            <text class="stat-label">获得勋章</text>
          </div>
        </div>
      </div>
    </div>

    <div class="bottom-bar">
      <div class="bottom-btn" onclick="goBack">
        <text>返回</text>
      </div>
    </div>
  </div>
</template>

